---
const year = new Date().getFullYear();

const socials = [
  { href: "https://github.com/shawntabrizi/", label: "github" },
  { href: "https://www.linkedin.com/in/shawn-tabrizi/", label: "linkedin" },
  { href: "https://twitter.com/shawntabrizi", label: "x/twitter" },
  { href: "https://stackexchange.com/users/1489538", label: "stackexchange" },
  { href: "https://www.instagram.com/shawntabrizi/", label: "instagram" },
  {
    href: "https://www.youtube.com/channel/UCl2YcZijUhWJweYeiOIYNdA",
    label: "youtube",
  },
  { href: "mailto:shawntabrizi@gmail.com", label: "email" },
];
---

<footer
  style="border-top: 1px solid var(--color-border);"
  class="px-6 py-8 mt-16"
>
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-wrap gap-x-4 gap-y-2 mb-4">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith("mailto:") ? undefined : "_blank"}
            rel="noopener"
            class="hover:underline text-sm"
            style="color: var(--color-text-muted);"
          >
            [{s.label}]
          </a>
        ))
      }
    </div>
    <p class="text-sm" style="color: var(--color-text-muted);">
      &copy; {year} Shawn Tabrizi
    </p>
  </div>
</footer>
