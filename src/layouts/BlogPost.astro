---
import Base from "./Base.astro";
import BlogSidebar from "../components/BlogSidebar.astro";
import { getSortedPosts, getSlug } from "../lib/blog";

interface Props {
  frontmatter: {
    title: string;
    date: Date;
    categories?: string[];
    tags?: string[];
    github?: string;
    customjs?: string[];
  };
  currentSlug: string;
}

const { frontmatter, currentSlug } = Astro.props;

// Compute everything in the layout to avoid serialization issues
const allPosts = await getSortedPosts();
const currentIndex = allPosts.findIndex((p) => getSlug(p) === currentSlug);
const prevPost =
  currentIndex > 0
    ? { slug: getSlug(allPosts[currentIndex - 1]), title: allPosts[currentIndex - 1].data.title }
    : null;
const nextPost =
  currentIndex < allPosts.length - 1
    ? { slug: getSlug(allPosts[currentIndex + 1]), title: allPosts[currentIndex + 1].data.title }
    : null;

const dateStr = frontmatter.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const tags = frontmatter.tags || frontmatter.categories || [];
---

<Base title={frontmatter.title}>
  <!-- Sidebar drawer (all sizes) -->
  <input type="checkbox" id="sidebar-toggle" class="hidden peer" />
  <label
    for="sidebar-toggle"
    class="fixed left-0 top-1/2 -translate-y-1/2 z-40 w-3 h-16 rounded-r cursor-pointer hover:w-4 transition-all"
    style="background: var(--color-border);"
    aria-label="Toggle post list"
  />
  <label
    for="sidebar-toggle"
    class="fixed inset-0 z-30 bg-black/50 hidden peer-checked:block cursor-pointer"
  />
  <div
    class="fixed left-0 top-0 z-40 h-full w-80 -translate-x-full peer-checked:translate-x-0 transition-transform overflow-y-auto p-6 pt-20"
    style="background: var(--color-bg); border-right: 1px solid var(--color-border);"
  >
    <BlogSidebar posts={allPosts} currentSlug={currentSlug} />
  </div>

  <div class="flex gap-8">

    <!-- Main content -->
    <div class="flex-1 min-w-0 max-w-3xl">
      <article>
        <header class="mb-8">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm" style="color: var(--color-text-muted);">
              {dateStr}
            </p>
            <label
              for="sidebar-toggle"
              class="text-xs cursor-pointer hover:underline"
              style="color: var(--color-text-muted);"
            >
              all posts &raquo;
            </label>
          </div>
          <h1 class="text-2xl font-bold mb-3">{frontmatter.title}</h1>
          {
            tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span
                    class="text-xs px-2 py-0.5 rounded"
                    style="background: var(--color-bg-secondary); color: var(--color-text-muted); border: 1px solid var(--color-border);"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            )
          }
          {
            frontmatter.github && (
              <p class="mt-3 text-sm">
                <a
                  href={`https://github.com/shawntabrizi/${frontmatter.github}`}
                  class="hover:underline"
                  style="color: var(--color-accent);"
                >
                  github.com/shawntabrizi/{frontmatter.github} &rarr;
                </a>
              </p>
            )
          }
        </header>
        <div class="prose prose-invert prose-a:text-[var(--color-accent)] prose-a:underline-offset-2 hover:prose-a:text-[var(--color-accent-hover)] max-w-none">
          <slot />
        </div>
      </article>

      <!-- Prev/Next navigation -->
      <nav
        class="flex justify-between mt-12 pt-6"
        style="border-top: 1px solid var(--color-border);"
      >
        {
          nextPost ? (
            <a
              href={`/blog/${nextPost.slug}/`}
              class="hover:underline text-sm"
              style="color: var(--color-accent);"
            >
              &larr; {nextPost.title}
            </a>
          ) : (
            <span />
          )
        }
        {
          prevPost ? (
            <a
              href={`/blog/${prevPost.slug}/`}
              class="hover:underline text-sm text-right"
              style="color: var(--color-accent);"
            >
              {prevPost.title} &rarr;
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </div>
  </div>

  {
    frontmatter.customjs &&
      frontmatter.customjs.map((src) => <script src={src} defer />)
  }
</Base>
