---
import Base from "../layouts/Base.astro";
---

<Base title="404">
  <div class="py-16 text-center">
    <h1 class="text-4xl font-bold mb-4">404</h1>
    <p style="color: var(--color-text-muted);" class="mb-8">
      Page not found.
    </p>
    <a
      href="/"
      class="hover:underline"
      style="color: var(--color-accent);"
    >
      &larr; back home
    </a>
  </div>
</Base>
