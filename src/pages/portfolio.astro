---
import Base from "../layouts/Base.astro";

interface Repo {
  name: string;
  stargazers_count: number;
  fork: boolean;
  forks_count: number;
  homepage: string | null;
  html_url: string;
  language: string | null;
  description: string | null;
}

async function fetchAllRepos(): Promise<Repo[]> {
  const repos: Repo[] = [];
  let page = 1;
  const headers: Record<string, string> = {
    Accept: "application/vnd.github.v3+json",
  };
  if (import.meta.env.GITHUB_TOKEN) {
    headers["Authorization"] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
  }
  while (true) {
    const res = await fetch(
      `https://api.github.com/users/shawntabrizi/repos?per_page=100&page=${page}`,
      { headers }
    );
    const data: Repo[] = await res.json();
    if (!data.length) break;
    repos.push(...data);
    page++;
  }
  return repos.sort((a, b) => b.stargazers_count - a.stargazers_count);
}

const repos = await fetchAllRepos();
const ownRepos = repos.filter((r) => !r.fork);
const forkRepos = repos.filter((r) => r.fork);
---

<Base title="Portfolio" description="Open source projects by Shawn Tabrizi">
  <h1 class="text-2xl font-bold mb-8">Portfolio</h1>

  <h2 class="text-lg font-bold mb-4" style="color: var(--color-text-muted);">
    My Repos
  </h2>
  <div class="overflow-x-auto mb-12">
    <table class="w-full text-sm" style="border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 1px solid var(--color-border);">
          <th class="text-left py-2 pr-4 font-bold" style="color: var(--color-text-muted);">Name</th>
          <th class="text-right py-2 px-4 font-bold" style="color: var(--color-text-muted);">Stars</th>
          <th class="text-left py-2 px-4 font-bold hidden md:table-cell" style="color: var(--color-text-muted);">Lang</th>
          <th class="text-left py-2 pl-4 font-bold hidden lg:table-cell" style="color: var(--color-text-muted);">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          ownRepos.map((repo) => (
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td class="py-2 pr-4">
                <a
                  href={repo.homepage || repo.html_url}
                  target="_blank"
                  rel="noopener"
                  class="hover:underline"
                  style="color: var(--color-accent);"
                >
                  {repo.name}
                </a>
              </td>
              <td
                class="text-right py-2 px-4"
                style="color: var(--color-warning);"
              >
                {repo.stargazers_count > 0 ? `★ ${repo.stargazers_count}` : ""}
              </td>
              <td
                class="py-2 px-4 hidden md:table-cell"
                style="color: var(--color-text-muted);"
              >
                {repo.language || "—"}
              </td>
              <td
                class="py-2 pl-4 hidden lg:table-cell truncate max-w-md"
                style="color: var(--color-text-muted);"
              >
                {repo.description || ""}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <h2 class="text-lg font-bold mb-4" style="color: var(--color-text-muted);">
    Contributing To
  </h2>
  <div class="overflow-x-auto">
    <table class="w-full text-sm" style="border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 1px solid var(--color-border);">
          <th class="text-left py-2 pr-4 font-bold" style="color: var(--color-text-muted);">Name</th>
          <th class="text-left py-2 px-4 font-bold hidden md:table-cell" style="color: var(--color-text-muted);">Lang</th>
          <th class="text-left py-2 pl-4 font-bold hidden lg:table-cell" style="color: var(--color-text-muted);">Description</th>
        </tr>
      </thead>
      <tbody>
        {
          forkRepos.map((repo) => (
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td class="py-2 pr-4">
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener"
                  class="hover:underline"
                  style="color: var(--color-accent);"
                >
                  {repo.name}
                </a>
              </td>
              <td
                class="py-2 px-4 hidden md:table-cell"
                style="color: var(--color-text-muted);"
              >
                {repo.language || "—"}
              </td>
              <td
                class="py-2 pl-4 hidden lg:table-cell truncate max-w-md"
                style="color: var(--color-text-muted);"
              >
                {repo.description || ""}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</Base>
