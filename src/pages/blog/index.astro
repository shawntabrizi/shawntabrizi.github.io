---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = await getCollection("blog");
const sorted = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function getSlug(post: (typeof posts)[0]): string {
  if (post.data.slug) {
    const parts = post.data.slug.replace(/^\/|\/$/g, "").split("/");
    return parts[parts.length - 1];
  }
  return post.id.replace(/^\d{4}-\d{2}-\d{2}-/, "").replace(/\.md$/, "");
}
---

<Base title="Blog" description="All blog posts by Shawn Tabrizi">
  <h1 class="text-2xl font-bold mb-8">Blog</h1>
  <div class="space-y-3">
    {
      sorted.map((post) => {
        const slug = getSlug(post);
        const date = post.data.date.toISOString().slice(0, 10);
        const category = post.data.categories?.[0] || post.data.tags?.[0] || "";
        return (
          <div class="flex flex-wrap gap-x-4 items-baseline">
            <span
              class="text-sm shrink-0"
              style="color: var(--color-text-muted);"
            >
              {date}
            </span>
            <a
              href={`/blog/${slug}/`}
              class="hover:underline flex-1 min-w-0"
              style="color: var(--color-text);"
            >
              {post.data.title}
            </a>
            {category && (
              <span
                class="text-xs shrink-0"
                style="color: var(--color-text-muted);"
              >
                [{category.toLowerCase()}]
              </span>
            )}
          </div>
        );
      })
    }
  </div>
</Base>
