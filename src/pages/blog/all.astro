---
import { getSortedPosts, getSlug } from "../../lib/blog";
import Base from "../../layouts/Base.astro";

const sorted = await getSortedPosts();
---

<Base title="All Posts" description="All blog posts by Shawn Tabrizi">
  <h1 class="text-2xl font-bold mb-8">All Posts</h1>
  <div class="space-y-3">
    {
      sorted.map((post) => {
        const slug = getSlug(post);
        const date = post.data.date.toISOString().slice(0, 10);
        const category =
          post.data.categories?.[0] || post.data.tags?.[0] || "";
        return (
          <div class="flex flex-wrap gap-x-4 items-baseline">
            <span
              class="text-sm shrink-0"
              style="color: var(--color-text-muted);"
            >
              {date}
            </span>
            <a
              href={`/blog/${slug}/`}
              class="hover:underline flex-1 min-w-0"
              style="color: var(--color-text);"
            >
              {post.data.title}
            </a>
            {category && (
              <a
                href={`/blog/tag/${category.toLowerCase()}/`}
                class="text-xs shrink-0 hover:underline"
                style="color: var(--color-text-muted);"
              >
                [{category.toLowerCase()}]
              </a>
            )}
          </div>
        );
      })
    }
  </div>
</Base>
