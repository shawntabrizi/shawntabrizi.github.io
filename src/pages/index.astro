---
import Base from "../layouts/Base.astro";
---

<Base>
  <div class="max-w-2xl">
    <div class="flex items-center gap-6 mb-8">
      <img
        src="/assets/images/avatar.jpg"
        alt="Shawn Tabrizi"
        class="w-20 h-20 rounded object-cover shrink-0"
      />
      <div>
        <h1 class="text-2xl font-bold mb-1">Hello, my name is Shawn Tabrizi.</h1>
        <p class="text-sm" style="color: var(--color-text-muted);">
          educator · builder · student
        </p>
      </div>
    </div>

    <div class="prose prose-invert prose-a:text-[var(--color-accent)] hover:prose-a:text-[var(--color-accent-hover)]">
      <p>
        I grew up in the California Bay Area. I started programming at 13, trying to hack
        my PlayStation Portable. The PSP homebrew community showed me what was
        possible with code, and I never looked back.
      </p>

      <p>
        I studied physics and mathematics at UC Santa Barbara's
        <a href="https://ccs.ucsb.edu/">College of Creative Studies</a>, then
        joined Microsoft as a Program Manager, building identity infrastructure for Azure.
      </p>

      <p>
        Today I'm a lead developer for
        <a href="https://polkadot.com/">Polkadot</a> at
        <a href="https://www.parity.io/">Parity Technologies</a>, focused on
        building infrastructure for a decentralized web. I also serve as an
        Architect on the
        <a href="https://github.com/polkadot-fellows">Polkadot Fellowship</a>
        and a lead instructor with the
        <a href="https://github.com/Polkadot-Blockchain-Academy/">Polkadot Blockchain Academy</a>.
      </p>

      <p>
        Based in Puerto Rico. I write here about the things I build and the
        ideas I'm exploring.
        <span class="italic">Discovery through experience</span>.
      </p>
    </div>
  </div>
</Base>
